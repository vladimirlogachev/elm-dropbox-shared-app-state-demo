{
  "private": true,
  "type": "module",
  "engines": {
    "npm": ">=10.2.3 <11.0.0",
    "node": ">=22.17.0 <23.0.0"
  },
  "scripts": {
    "start": "vite",
    "build": "vite build --base=/elm-dropbox-shared-app-state-demo",
    "test": "elm-test",
    "format-fix-all": "elm-format --yes src/ review/",
    "format-validate": "elm-format --validate src/ review/",
    "review": "elm-review",
    "review-fix-interactive": "elm-review --fix",
    "review-fix-all": "yes | elm-review --fix-all",
    "fix": "npm run format-fix-all && npm run review-fix-all && npm run build && npm test",
    "check-and-build": "npm run build && npm run format-validate && npm test && npm run review"
  },
  "devDependencies": {
    "@types/node": "^22.17",
    "elm-format": "^0.8.7",
    "elm-land": "^0.20.1",
    "elm-review": "^2.10.2",
    "elm-test": "^0.19.1-revision17",
    "vite": "^7.2.2"
  },
  "dependencies": {
    "elm": "^0.19.1-6",
    "elm-debug-transformer": "^1.2.1",
    "vite-plugin-elm": "^3.0.1"
  }
}
